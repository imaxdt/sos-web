{
  "name": "sos-web",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "tests/e2e"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "dev:backend": "npm run dev -w backend",
    "dev:frontend": "npm run dev -w frontend",
    "db:generate": "npm run db:generate -w backend",
    "db:migrate": "npm run db:migrate -w backend",
    "check": "npm run check -w backend && npm run build -w frontend",
    "test:e2e": "npm run test -w tests/e2e",
    "test:e2e:headed": "npm run test:headed -w tests/e2e"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
